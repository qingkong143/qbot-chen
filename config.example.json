{
  "main_model": {
    "provider": "deepseek",
    "model": "deepseek-v4-flash",
    "url": "https://api.deepseek.com/chat/completions",
    "api_key": "sk-xxx",
    "temperature": 0.3,
    "max_tokens": 65536,
    "context_window": 1000000
  },
  "summary_model": {
    "provider": "agnes",
    "model": "agnes-1.5-flash",
    "url": "https://apihub.agnes-ai.com/v1/chat/completions",
    "api_key": "sk-xxx",
    "temperature": 0.3,
    "max_tokens": 65500,
    "context_window": 128000
  },
  "embedding": {
    "provider": "siliconflow",
    "model": "Qwen/Qwen3-Embedding-8B",
    "api_url": "https://api.siliconflow.cn/v1/embeddings",
    "api_key": "sk-xxx"
  },
  "ocr": {
    "enabled": true,
    "provider": "siliconflow",
    "model": "Qwen/Qwen3.6-27B",
    "url": "https://api.siliconflow.cn/v1/chat/completions",
    "api_key": "sk-xxx",
    "max_images_per_message": 2,
    "timeout_seconds": 45
  },
  "napcat": {
    "ws_url": "ws://127.0.0.1:3001",
    "http_url": "http://127.0.0.1:3000",
    "token": "your-napcat-token",
    "group_whitelist": [709508212],
    "private_whitelist": [],
    "admin_users": ["your-qq-number"],
    "bot_aliases": ["机器人", "bot"],
    "max_private_agents": 500
  },
  "mcp_servers": [
    {
      "name": "fetch",
      "url": "https://mcp.api-inference.modelscope.net/xxx/mcp",
      "transport": "streamable_http",
      "headers": {
        "Authorization": "Bearer your-api-key"
      },
      "enabled": true
    }
  ],
  "system_prompt": "你在 QQ 群里和大家日常聊天。说话自然一点，像普通人，不要像客服或写作文。普通回复尽量短，能一句话说清就一句话。",
  "pipeline": {
    "silentChance": 1.0,
    "unmentionedEvalChance": 1.0,
    "idleCompensationSeconds": 7200,
    "idleQuietStartHour": 0,
    "idleQuietEndHour": 7,
    "cooldownSeconds": 30
  },
  "a_memorix": {
    "enabled": true,
    "data_dir": "data/a-memorix",
    "integration": {
      "enable_query": true,
      "inject_profile": true,
      "write_person_facts": true,
      "write_chat_summary": true,
      "feedback_correction": false
    },
    "writeback": {
      "after_reply": true,
      "message_window": 30,
      "min_importance": 0.65,
      "summary_interval_minutes": 30
    },
    "retrieval": {
      "max_facts": 8,
      "max_episodes": 3,
      "max_profile_chars": 800
    }
  },
  "ban_words": ["垃圾广告", "微信号"],
  "ad_keywords": ["加微信", "VX:", "VX：", "微信:", "微信号", "QQ:", "QQ号", "加我", "扫我", "关注+私信", "兼职", "刷单", "博彩", "彩票", "币圈"],
  "ban_regex": [],
  "commands": [
    {"prefix": "/", "name": "ping", "description": "测试在线"},
    {"prefix": "/", "name": "time", "description": "当前时间"},
    {"prefix": "/", "name": "mcp_tools", "description": "列出已连接的 MCP 工具"},
    {"prefix": "", "name": "赞我", "description": "给用户点赞"}
  ]
}
